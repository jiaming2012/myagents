# Productivity-tools env vars.
# Actual values belong in the repo-root .env (shared across tools);
# this file just documents what each tool needs.

# --- iCloud Calendar (cmd/events) -----------------------------------------
# Username: your Apple ID email (e.g. you@icloud.com).
# Password: an app-specific password — generate one at https://appleid.apple.com
#   → Sign-In and Security → App-Specific Passwords. Your real Apple ID
#   password will NOT work.
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=

# --- Todoist (cmd/todoist) ------------------------------------------------
# Get from https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=
